# Copy to .env for local dev. On Render these are set via the Blueprint/dashboard.

# PostgreSQL connection string.
# Render: auto-injected from the managed DB. Local: your local/Supabase Postgres URL.
DATABASE_URL=postgres://user:password@localhost:5432/iam_nest

# Set to "false" to disable TLS (e.g. a local Postgres without SSL).
# Leave unset on Render — managed Postgres needs SSL.
DATABASE_SSL=false

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5173

# Port the app listens on (Render injects this automatically; default 3000 locally).
PORT=3000

# JWT secrets — use long random values in production (Render can generate them).
JWT_SECRET=dev-only-secret-change-me
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me
JWT_EXPIRES_IN=300
JWT_REFRESH_EXPIRES_IN=604800
